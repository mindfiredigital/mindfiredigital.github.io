[{"id":34,"title":"ADAC (Architecture Diagram as Code)","short_description":"ADAC is a proof-of-concept tool and specification that enables defining, versioning, and visualizing cloud infrastructure using machine-readable code. It treats architecture diagrams as a single source of truth, helping teams keep infrastructure documentation accurate, auditable, and aligned with real system design while showcasing innovation in Full-Stack engineering and DevOps tooling.","github_repository_link":"https://github.com/mindfiredigital/adac-tools","documentation_link":"https://github.com/mindfiredigital/adac-tools/blob/main/README.md","project_type":"upcoming","date_created":"2026-02-05T10:10:41.000Z","date_updated":null,"status":"draft","shortDescription":"ADAC is a proof-of-concept tool and specification that enables defining, versioning, and visualizing cloud infrastructure using machine-readable code. It treats architecture diagrams as a single source of truth, helping teams keep infrastructure documentation accurate, auditable, and aligned with real system design while showcasing innovation in Full-Stack engineering and DevOps tooling.","githubUrl":"https://github.com/mindfiredigital/adac-tools","documentationUrl":"https://github.com/mindfiredigital/adac-tools/blob/main/README.md","stars":15,"tags":[],"lastPushedAt":"2026-03-23T05:36:01Z"},{"id":35,"title":"Agentic Web Starter","short_description":"Agentic Web Starter is a FastAPI-based backend template for building agentic and RAG-driven applications. It provides ready-to-use ingestion, retrieval, and chat APIs with integrated vector search (Qdrant) and persistent session memory (Redis), enabling teams to quickly develop, extend, and deploy production-oriented agentic workflows without rebuilding foundational backend infrastructure.","github_repository_link":"https://github.com/mindfiredigital/Agentic-Web-Starter","documentation_link":"https://github.com/mindfiredigital/Agentic-Web-Starter/blob/main/LICENSE","project_type":"upcoming","date_created":"2026-02-05T10:14:52.000Z","date_updated":null,"status":"draft","shortDescription":"Agentic Web Starter is a FastAPI-based backend template for building agentic and RAG-driven applications. It provides ready-to-use ingestion, retrieval, and chat APIs with integrated vector search (Qdrant) and persistent session memory (Redis), enabling teams to quickly develop, extend, and deploy production-oriented agentic workflows without rebuilding foundational backend infrastructure.","githubUrl":"https://github.com/mindfiredigital/Agentic-Web-Starter","documentationUrl":"https://github.com/mindfiredigital/Agentic-Web-Starter/blob/main/LICENSE","stars":17,"tags":["agent","ai","ai-agents","aiagent","fastapi"],"lastPushedAt":"2026-03-10T07:28:56Z"}]